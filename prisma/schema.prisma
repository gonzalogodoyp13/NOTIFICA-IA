generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  officeName String
  createdAt  DateTime   @default(now())
  auditLogs  AuditLog[]
  demandas   Demanda[]

  @@map("users")
}

model Office {
  id             Int             @id @default(autoincrement())
  nombre         String
  createdAt      DateTime        @default(now())
  estampos       Estampo[]       @relation("OfficeEstampos")
  auditLogs      AuditLog[]
  demandas       Demanda[]
  estampoCustoms EstampoCustom[] @relation("OfficeEstampoCustoms")

  @@map("offices")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  officeId  Int
  tabla     String
  accion    String
  diff      Json?
  createdAt DateTime @default(now())
  office    Office   @relation(fields: [officeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Abogado {
  id        Int            @id @default(autoincrement())
  officeId  Int
  nombre    String?
  rut       String?
  direccion String?
  comuna    String?
  telefono  String?
  email     String?
  bancoId   Int?
  createdAt DateTime       @default(now())
  bancos    AbogadoBanco[] @relation("AbogadoBancos")
  banco     Banco?         @relation(fields: [bancoId], references: [id])
  aranceles Arancel[]      @relation("AbogadoAranceles")
  demandas  Demanda[]

  @@index([bancoId])
  @@index([officeId])
  @@map("abogados")
}

model Banco {
  id            Int            @id @default(autoincrement())
  officeId      Int
  nombre        String
  cuenta        String?
  createdAt     DateTime       @default(now())
  abogadoBancos AbogadoBanco[] @relation("BancoAbogados")
  abogados      Abogado[]
  aranceles     Arancel[]      @relation("BancoAranceles")

  @@index([officeId])
  @@map("bancos")
}

model AbogadoBanco {
  id        Int      @id @default(autoincrement())
  officeId  Int
  abogadoId Int
  bancoId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  abogado   Abogado  @relation("AbogadoBancos", fields: [abogadoId], references: [id], onDelete: Cascade)
  banco     Banco    @relation("BancoAbogados", fields: [bancoId], references: [id], onDelete: Cascade)

  @@unique([officeId, abogadoId, bancoId])
  @@index([abogadoId])
  @@index([bancoId])
  @@index([officeId])
  @@map("abogado_bancos")
}

model Arancel {
  id        Int      @id @default(autoincrement())
  officeId  Int
  bancoId   Int
  abogadoId Int?
  estampoId String
  monto     Int
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  abogado   Abogado? @relation("AbogadoAranceles", fields: [abogadoId], references: [id], onDelete: Cascade)
  banco     Banco    @relation("BancoAranceles", fields: [bancoId], references: [id], onDelete: Cascade)
  estampo   Estampo  @relation("EstampoAranceles", fields: [estampoId], references: [id], onDelete: Cascade)

  @@unique([officeId, bancoId, abogadoId, estampoId])
  @@index([officeId, bancoId, estampoId])
  @@index([officeId, abogadoId, estampoId])
  @@index([officeId, bancoId])
  @@index([estampoId])
  @@map("aranceles")
}

model Comuna {
  id         Int         @id @default(autoincrement())
  officeId   Int
  nombre     String
  region     String?
  createdAt  DateTime    @default(now())
  ejecutados Ejecutado[]

  @@index([officeId])
  @@map("comunas")
}

model Materia {
  id        Int       @id @default(autoincrement())
  officeId  Int
  nombre    String
  createdAt DateTime  @default(now())
  demandas  Demanda[]

  @@index([officeId])
  @@map("materias")
}

model Demanda {
  id         String      @id @default(cuid())
  rol        String      @unique
  tribunalId Int
  caratula   String
  cuantia    Float
  abogadoId  Int
  officeId   Int
  userId     String
  createdAt  DateTime    @default(now())
  materiaId  Int?
  roles      RolCausa?
  abogados   Abogado     @relation(fields: [abogadoId], references: [id])
  materia    Materia?    @relation(fields: [materiaId], references: [id])
  offices    Office      @relation(fields: [officeId], references: [id])
  tribunales tribunales  @relation(fields: [tribunalId], references: [id])
  users      User        @relation(fields: [userId], references: [id])
  ejecutados Ejecutado[]

  @@map("demandas")
}

model Ejecutado {
  id        String  @id @default(cuid())
  demandaId String
  nombre    String
  rut       String
  direccion String?
  comunaId  Int?
  rvm       Json?
  comunas   Comuna? @relation(fields: [comunaId], references: [id])
  demandas  Demanda @relation(fields: [demandaId], references: [id])
  notificaciones Notificacion[]

  @@map("ejecutados")
}

model diligencia_tipos {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  officeId    Int
  createdAt   DateTime @default(now())

  @@index([officeId])
}

model tribunales {
  id        Int       @id @default(autoincrement())
  officeId  Int
  nombre    String
  direccion String?
  comuna    String?
  createdAt DateTime  @default(now())
  demandas  Demanda[]

  @@index([officeId])
}

model RolCausa {
  id          String       @id
  demandaId   String?      @unique
  officeId    Int
  rol         String
  tribunalId  String
  estado      EstadoRol    @default(pendiente)
  createdAt   DateTime     @default(now())
  diligencias Diligencia[]
  documentos  Documento[]
  notas       Nota[]
  recibos     Recibo[]
  demanda     Demanda?     @relation(fields: [demandaId], references: [id])
  tribunal    Tribunal     @relation(fields: [tribunalId], references: [id])

  @@index([officeId, createdAt])
  @@index([rol])
}

model Diligencia {
  id         String           @id @default(cuid())
  rolId      String
  tipoId     String
  estado     EstadoDiligencia @default(pendiente)
  fecha      DateTime
  meta       Json?
  createdAt  DateTime         @default(now())
  rol        RolCausa         @relation(fields: [rolId], references: [id])
  tipo       DiligenciaTipo   @relation(fields: [tipoId], references: [id])
  documentos Documento[]
  notificaciones Notificacion[]

  @@index([rolId, createdAt])
}

model Notificacion {
  id           String     @id
  diligenciaId String
  meta         Json?
  createdAt    DateTime?
  updatedAt    DateTime?
  voidedAt     DateTime?
  voidReason   String?
  voidedByUserId String?
  ejecutadoId  String?
  diligencia   Diligencia @relation(fields: [diligenciaId], references: [id])
  ejecutado    Ejecutado? @relation(fields: [ejecutadoId], references: [id], onDelete: Restrict)
  documentos   Documento[]

  @@index([ejecutadoId])
  @@map("notificaciones")
}

model Documento {
  id            String       @id @default(cuid())
  rolId         String
  diligenciaId  String?
  notificacionId String?
  estampoId     String?
  nombre        String
  tipo          String
  pdfId         String?
  version       Int          @default(1)
  createdAt     DateTime     @default(now())
  textoEditado  String?
  estampoBaseId Int?
  voidedAt      DateTime?
  voidReason    String?
  voidedByUserId String?
  diligencia    Diligencia?  @relation(fields: [diligenciaId], references: [id])
  notificacion  Notificacion? @relation(fields: [notificacionId], references: [id])
  estampoBase   EstampoBase? @relation(fields: [estampoBaseId], references: [id])
  estampo       Estampo?     @relation(fields: [estampoId], references: [id])
  rol           RolCausa     @relation(fields: [rolId], references: [id])

  @@index([rolId, createdAt])
}

model Nota {
  id        String   @id @default(cuid())
  rolId     String
  userId    String
  contenido String
  createdAt DateTime @default(now())
  rol       RolCausa @relation(fields: [rolId], references: [id])

  @@index([rolId, createdAt])
}

model Recibo {
  id        String   @id @default(cuid())
  rolId     String
  monto     Float
  medio     String
  ref       String?
  createdAt DateTime @default(now())
  rol       RolCausa @relation(fields: [rolId], references: [id])

  @@index([rolId, createdAt])
}

model Tribunal {
  id        String     @id @default(cuid())
  officeId  Int
  nombre    String
  direccion String?
  comuna    String?
  createdAt DateTime   @default(now())
  roles     RolCausa[]
}

model DiligenciaTipo {
  id          String       @id @default(cuid())
  officeId    Int
  nombre      String
  descripcion String?
  createdAt   DateTime     @default(now())
  diligencias Diligencia[]
}

model Estampo {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  activo     Boolean     @default(true)
  fileUrl    String
  nombre     String
  officeId   Int
  tipo       String
  contenido  String?
  documentos Documento[]
  office     Office      @relation("OfficeEstampos", fields: [officeId], references: [id])
  aranceles  Arancel[]   @relation("EstampoAranceles")
}

model EstampoBase {
  id              Int             @id @default(autoincrement())
  slug            String          @unique
  nombreVisible   String
  categoria       String
  descripcion     String?
  textoTemplate   String
  variablesSchema Json
  wizardSchema    Json
  version         Int             @default(1)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  documentos      Documento[]
  customs         EstampoCustom[]

  @@index([categoria, isActive])
  @@index([slug])
  @@map("estampo_bases")
}

model EstampoCustom {
  id                 Int         @id @default(autoincrement())
  baseId             Int
  officeId           Int
  nombreOverride     String?
  textoTemplate      String
  isDefaultForOffice Boolean     @default(true)
  isActive           Boolean     @default(true)
  version            Int         @default(1)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  base               EstampoBase @relation(fields: [baseId], references: [id], onDelete: Cascade)
  office             Office      @relation("OfficeEstampoCustoms", fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([baseId, officeId], name: "EstampoCustom_base_office_unique")
  @@index([officeId])
  @@index([baseId])
  @@index([officeId, isActive])
  @@map("estampo_customs")
}

enum EstadoRol {
  pendiente
  en_proceso
  terminado
  archivado
}

enum EstadoDiligencia {
  pendiente
  completada
  fallida
}
